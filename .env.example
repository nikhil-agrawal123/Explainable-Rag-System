# =============================================================================
# DataForge — Environment Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# --- Ollama (Local LLMs) ---
# REQUIRED for core RAG functionality
OLLAMA_HOST=http://localhost:11434
OLLAMA_DOMAIN_MODEL=qwen3.5:9b
OLLAMA_DOMAIN_MODEL_SMALL=qwen3.5:0.8b
OLLAMA_EMBEDDING_MODEL=qwen3-embedding:8b

# --- Supabase (Auth) ---
# REQUIRED for user signup / login
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# --- JWT (Token config) ---
# REQUIRED — generate a strong secret:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-random-64-char-hex-string
JWT_EXPIRY_MINUTES=60

# --- LangChain / LangSmith (optional tracing) ---
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_langsmith_api_key
# LANGCHAIN_PROJECT=dataforge

# --- OpenAI / HuggingFace (optional fallback LLMs) ---
# OPENAI_API_KEY=sk-...
# HUGGINGFACE_API_KEY=hf_...

# --- Qdrant (optional cloud vector DB) ---
# QDRANT_API_KEY=...
# QDRANT_CLUSTER_ENDPOINT=https://...

# --- Logging ---
# One of: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
LOG_LEVEL=INFO
